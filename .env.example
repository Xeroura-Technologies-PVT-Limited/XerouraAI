# Django
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
# Comma-separated, no trailing comma. With DEBUG=True, *.ngrok-free.app / *.ngrok-free.dev / *.ngrok.io are added automatically.
ALLOWED_HOSTS=localhost,127.0.0.1
# If DEBUG=False but you still use ngrok for webhooks, set True (otherwise only ALLOWED_HOSTS above apply).
ALLOW_NGROK_SUBDOMAINS=False
# Google Cloud Run (or any TLS-terminating proxy): set True so Django sees HTTPS.
TRUST_X_FORWARDED_PROTO=False

# Database (Docker PostgreSQL)
POSTGRES_DB=support_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://postgres:changeme@db:5432/support_agent

# Redis
REDIS_URL=redis://redis:6379/0

# AI
ANTHROPIC_API_KEY=sk-ant-xxxx

# WhatsApp
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=my-verify-token

# Gmail
GOOGLE_CREDENTIALS_PATH=/app/credentials/google-credentials.json
GMAIL_WATCH_ADDRESS=support@yourdomain.com

# Ngrok (optional)
NGROK_AUTHTOKEN=

# Voice (Twilio + optional ElevenLabs) — dashboard Settings → Voice + docs/VOICE_AND_CALLS.md
PUBLIC_BASE_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
VOICE_ESCALATION_FORWARD_NUMBER=
