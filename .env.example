# Django
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Docker PostgreSQL)
POSTGRES_DB=support_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://postgres:changeme@db:5432/support_agent

# Redis
REDIS_URL=redis://redis:6379/0

# AI
ANTHROPIC_API_KEY=sk-ant-xxxx

# WhatsApp
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=my-verify-token

# Gmail
GOOGLE_CREDENTIALS_PATH=/app/credentials/google-credentials.json
GMAIL_WATCH_ADDRESS=support@yourdomain.com

# Ngrok (optional)
NGROK_AUTHTOKEN=

# Voice (Twilio + optional ElevenLabs) — dashboard Settings → Voice + docs/VOICE_AND_CALLS.md
PUBLIC_BASE_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
VOICE_ESCALATION_FORWARD_NUMBER=
